# Copy to .env and fill in. Real env files are git-ignored.
ANTHROPIC_API_KEY=
# MiniMax fallback — used when Claude is unavailable (or run on MiniMax alone by
# leaving ANTHROPIC_API_KEY blank). Get a key at https://platform.minimax.io.
# MINIMAX_API_KEY=
# NAV pricing oracle: 'fundamental' (default, valued from asset cash flows),
# 'pyth' (live Hermes price feeds for tokenized assets), or 'switchboard' (future).
# NAV_ORACLE_PROVIDER=fundamental
# PYTH_HERMES_URL=https://hermes.pyth.network
# Optional overrides:
# AGENT_MODEL=claude-opus-4-8
# MINIMAX_MODEL=MiniMax-M2
# PORT=8000
